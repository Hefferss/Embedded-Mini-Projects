const int ldrPin = A0;
const int speakerPin = 8;

void setup() {
  pinMode(speakerPin, OUTPUT);
}

void loop() {
  int lightValue = analogRead(ldrPin);

  if (lightValue < 500) {      // Dark
    tone(speakerPin, 1000);    // Play a 1000 Hz tone
  } else {                     // Bright
    noTone(speakerPin);        // Stop the sound
  }

  delay(100);
}