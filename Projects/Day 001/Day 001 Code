#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

void setup() {
  lcd.init();
  lcd.backlight();
  Serial.begin(9600);

  lcd.setCursor(0, 0);
  lcd.print("Pot value:");
}

void loop() {
  int raw = analogRead(A0);
  float voltage = raw * (5.0 / 1023.0);

  lcd.setCursor(0, 1);
  lcd.print("                ");
  lcd.setCursor(0, 1);
  lcd.print(raw);
  lcd.print("  (");
  lcd.print(voltage, 2);
  lcd.print("V)");

  Serial.print("Raw: ");
  Serial.print(raw);
  Serial.print("  Voltage: ");
  Serial.println(voltage, 2);

  delay(200);
}