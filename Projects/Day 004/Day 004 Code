#include <FastLED.h>

#define VIBRATION_PIN 10
#define LED_PIN       6
#define NUM_LEDS      8

CRGB leds[NUM_LEDS];
bool lastState = HIGH;

void setup() {
  Serial.begin(9600);
  pinMode(VIBRATION_PIN, INPUT_PULLUP);
  FastLED.addLeds<WS2812B, LED_PIN, GRB>(leds, NUM_LEDS);
  FastLED.setBrightness(60);
}

void loop() {
  bool state = digitalRead(VIBRATION_PIN);

  if (state == LOW && lastState == HIGH) {
    Serial.println("VIBRATION! VIBRATION!");

    for (int i = 0; i < NUM_LEDS * 3; i++) {
      int led = i % NUM_LEDS;
      leds[led] = CHSV(random8(), 255, 200);
      FastLED.show();
      delay(80);
    }

    for (int b = 0; b < 10; b++) {
      for (int i = 0; i < NUM_LEDS; i++) leds[i].fadeLightBy(180);
      FastLED.show();
      delay(30);
    }
  }

  lastState = state;
}