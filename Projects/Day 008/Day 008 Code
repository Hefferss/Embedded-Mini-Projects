#define SPEAKER 9

#define BTN_C  2
#define BTN_E  3
#define BTN_G  4

#define NOTE_C 262
#define NOTE_E 330
#define NOTE_G 392

void setup() {
  pinMode(SPEAKER, OUTPUT);
  pinMode(BTN_C, INPUT_PULLUP);
  pinMode(BTN_E, INPUT_PULLUP);
  pinMode(BTN_G, INPUT_PULLUP);
}

void loop() {
  if (digitalRead(BTN_C) == LOW) {
    tone(SPEAKER, NOTE_C);
  } else if (digitalRead(BTN_E) == LOW) {
    tone(SPEAKER, NOTE_E);
  } else if (digitalRead(BTN_G) == LOW) {
    tone(SPEAKER, NOTE_G);
  } else {
    noTone(SPEAKER);
  }
}